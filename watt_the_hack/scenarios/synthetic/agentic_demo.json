  "events": [
    {
      "id": "brief",
      "type": "qualitative_alert",
      "severity": "info",
      "at_step": 0,
      "end_step": 0,
      "title": "Demo Grid Authority \u2014 Shift Briefing",
      "description": "Welcome, operator. Directives for this single-node feeder arrive here, as plain English, in state['alerts']. Your job: read them in plan()/replan(), cache a numeric target, and act on it in step() \u2014 never call the LLM inside step(). Tonight's directive: the Authority requires you to hold a battery reserve during the evening peak (4:00 PM to 7:00 PM). Keep state-of-charge at or above FIFTY percent for the whole window. A shortfall is penalised per step.",
      "icon": "info"
    },
    {
      "id": "reserve_raise",
      "type": "qualitative_alert",
      "severity": "high",
      "at_step": 24,
      "end_step": 27,
      "title": "Demo Grid Authority \u2014 Reserve Floor Raised",
      "description": "Update to this morning's briefing. A heat event is forecast for this evening. The reserve floor for tonight's 4:00 PM to 7:00 PM window is RAISED from fifty to SEVENTY percent of pack capacity. Pre-position early \u2014 midday solar is the cheapest energy you'll see all day. This directive supersedes the earlier fifty percent figure.",
      "icon": "shield"
    },
    {
      "id": "vendor_noise",
      "type": "qualitative_alert",
      "severity": "info",
      "at_step": 40,
      "end_step": 42,
      "title": "BatteryCo Newsletter \u2014 Quarterly Market Recap",
      "description": "Hi from your friendly inverter vendor! FCAS prices stayed firm last quarter and our new firmware is rolling out soon. No action required \u2014 just keeping you in the loop. Not all messages are directives; a good agent ignores the noise.",
      "icon": "mail"
    },
    {
      "id": "evening_reserve_window",
      "type": "compliance_window",
      "severity": "high",
      "at_step": 64,
      "end_step": 76,
      "min_soc_floor": 0.7,
      "penalty_multiplier": 0.05,
      "title": "Evening Reserve Window",
      "description": "Engine-enforced. SOC below the announced floor is penalised per step. Announced at step 0 and revised at step 24.",
      "icon": "shield"
    }
  ],
  "narrative": {
    "one_liner": "A one-day teaching slice of the agentic track: read a plain-English directive, translate it to a SOC target, and hold it through the evening peak.",
    "teaching_moment": "This scenario only rewards the agentic loop \u2014 plan() reads the shift briefing, replan() catches the mid-morning floor revision, and step() holds the cached target. A do-nothing or pure-arbitrage controller drains into the evening price peak and eats the reserve-shortfall penalty. The real agentic scenarios (Operator's Mandate, Cybersecurity) add conflicting senders, phishing traps, FCAS dispatches, and forecast poisoning on top of this loop \u2014 but the loop is the same.",
    "context": "You run a single-node feeder for one simulated day. The Demo Grid Authority issues a reserve directive at the start of your shift and revises it mid-morning. A vendor newsletter is noise, not a directive. Score is raw cost \u2014 lower wins.",
    "explainer_url": ""
  },
